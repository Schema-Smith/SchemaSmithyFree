<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SchemaHammer.ViewModels.Editors"
             x:Class="SchemaHammer.Views.Editors.TableEditorView"
             x:DataType="vm:TableEditorViewModel">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="8" Margin="8">
            <TextBlock Text="{Binding EditorLabel}" Classes="editor-title" />

            <Border Classes="section-header-border">
                <TextBlock Classes="section-header" Text="Settings" />
            </Border>
            <StackPanel Margin="4,0,0,0" Spacing="8">
                <StackPanel>
                    <TextBlock Text="Compression Type" Margin="0,0,0,2" />
                    <TextBox Text="{Binding CompressionType}" IsReadOnly="True" />
                </StackPanel>
                <Grid ColumnDefinitions="*,*">
                    <CheckBox Grid.Column="0" Content="Is Temporal" IsChecked="{Binding IsTemporal}" IsEnabled="False" />
                    <CheckBox Grid.Column="1" Content="Update Fill Factor" IsChecked="{Binding UpdateFillFactor}" IsEnabled="False" />
                </Grid>
                <StackPanel>
                    <TextBlock Text="Old Name" Margin="0,0,0,2" />
                    <TextBox Text="{Binding OldName}" IsReadOnly="True" />
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
