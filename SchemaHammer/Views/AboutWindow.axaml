<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SchemaHammer.ViewModels"
        x:Class="SchemaHammer.Views.AboutWindow"
        x:DataType="vm:AboutViewModel"
        Title="About SchemaHammer"
        Width="400" Height="220"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <StackPanel Margin="24" Spacing="12">
        <TextBlock Text="{Binding AppName}"
                   FontSize="20" FontWeight="Bold"
                   Foreground="{DynamicResource SH.Accent.Ember}" />
        <TextBlock Text="{Binding Version, StringFormat='Version {0}'}" />
        <TextBlock Text="{Binding Description}"
                   TextWrapping="Wrap" />
        <TextBlock Text="{Binding GitHubUrl}"
                   Foreground="{DynamicResource SH.Accent.Ember}"
                   Cursor="Hand"
                   Name="GitHubLink"
                   TextDecorations="Underline" />
        <Button Content="OK"
                HorizontalAlignment="Right"
                MinWidth="80"
                Click="OnOkClick" />
    </StackPanel>
</Window>
