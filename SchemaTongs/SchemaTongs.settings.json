    },
    // Name will default to Database if not provided.
    // This becomes the folder name for the template that is exported as well as the template name.
    "Template": {
        "Name": ""
    },
    "ShouldCast": {
        "Tables": true,
        "Schemas": true,
        "UserDefinedTypes": true,
        "UserDefinedFunctions": true,
        "Views": true,
        "StoredProcedures": true,
        "TableTriggers": true,
        "Catalogs": true, // Full-Text Catalogs
        "StopLists": true, // Full-Text Stop Lists
        "DDLTriggers": true,
        "XMLSchemaCollections": true,
        "IndexedViews": true,
        "ScriptDynamicDependencyRemovalForFunctions": false,
        "ObjectList": "" // Comma-separated list of specific objects to extract (blank = all)
    }
}
